# Godot 4 generated cache & import artifacts
.godot/

# Export / build output
/build/
/export/
export_presets.cfg

# Mono/.NET (unused here, harmless to ignore)
.mono/
data_*/

# OS / editor cruft
.DS_Store
Thumbs.db
